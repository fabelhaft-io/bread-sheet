PORT=3000
NODE_ENV=development
DATABASE_URL=postgresql://admin:password@127.0.0.1:5432/breadsheet
# TLS for the runtime pg connection pool: disabled | verify-full (no default — must
# be explicit). Local Postgres has no TLS, so `disabled`. In prod use `verify-full`
# (RDS), which verifies the server cert against the RDS CA bundle baked into the image.
DB_SSL=disabled
# DB authentication method: password | iam (no default — must be explicit).
# Local dev uses password (static in DATABASE_URL). Prod uses iam (RDS IAM auth —
# mints short-lived tokens via @aws-sdk/rds-signer, fully keyless).
DB_AUTH=password
# Only needed when DB_AUTH=iam (used by scripts/start.sh to mint a token for migrations):
# DB_HOST=breadsheet-dev-database-1.cna48wy46m01.eu-west-1.rds.amazonaws.com
# DB_PORT=5432
# DB_USER=breadsheet_iam
# DB_NAME=breadsheet

SUPABASE_URL=https://<supabase_project>.supabase.co
SUPABASE_PUBLISHABLE_DEFAULT_KEY=<supabase_project_key>

AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET_NAME=breadsheet-images-local
# Which S3 backend the server talks to: localstack | aws (no default — must be explicit).
# localstack switches the SDK to path-style addressing, which LocalStack requires.
S3_MODE=localstack
#   - LocalStack:  http://<host-reachable-ip>:4566/breadsheet-images-local
#   - AWS:         https://<bucket>.s3.<region>.amazonaws.com  (or a CDN domain)
# Image URLs are assembled at READ time as `${assetBaseUrl}/${key}` — only
ASSET_BASE_URL=http://<host-reachable-ip>:4566/breadsheet-images-local
VISION_MODE=live
# Image plausibility / abuse gate on uploads: mock | gemini
PLAUSIBILITY_MODE=mock

# Gemini credentials. Needed when VISION_MODE=llm or PLAUSIBILITY_MODE=gemini.
# Two auth methods, chosen purely by env — the calling code is identical:
#   - Vertex AI (recommended; no long-lived key). Locally run
#     `gcloud auth application-default login` and the SDK uses that ADC. In prod
#     (Fargate) it uses keyless Workload Identity Federation — see the GCP_WORKLOAD_*
#     vars below. The calling code is the same in dev and prod.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project
GOOGLE_CLOUD_LOCATION=global
#   - OR the Gemini Developer API key from Google AI Studio (simplest, but a
#     long-lived secret). Set this INSTEAD of the three vars above.
# GEMINI_API_KEY=

# Workload Identity Federation (PROD / ECS Fargate ONLY — leave unset locally).
# When BOTH are set, the AWS task role impersonates the GCP service account
# keylessly (no credential file); unset → default ADC (gcloud login). Set both or
# neither. See services/gcpWorkloadIdentity.ts.
# GCP_WORKLOAD_IDENTITY_AUDIENCE=//iam.googleapis.com/projects/<num>/locations/global/workloadIdentityPools/<pool>/providers/<provider>
# GCP_SERVICE_ACCOUNT_EMAIL=<sa>@<project>.iam.gserviceaccount.com

LOG_LEVEL=debug
# Deep link scheme for /auth/callback. Use exp+breadsheet for Expo Go, breadsheet for production.
APP_DEEP_LINK_SCHEME=exp+breadsheet