{
  "name": "bread-sheet-server",
  "version": "1.0.0",
  "description": "REST Backend for BreadSheet",
  "type": "module",
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:deploy": "npx prisma migrate deploy && npx prisma generate",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "npm run prisma:generate && nodemon --legacy-watch --watch src --ext ts --exec \"tsx src/server.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "JanoNick",
  "license": "Apache-2.0",
  "devDependencies": {
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.16.0",
    "@types/sharp": "^0.31.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.975.0",
    "@google-cloud/vision": "^5.3.6",
    "@google/genai": "^1.52.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.6.0",
    "@supabase/supabase-js": "^2.98.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "file-type": "^22.0.1",
    "multer": "^2.1.1",
    "pg": "^8.17.2",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  }
}
