meta {
  name: Get my ratings
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/users/me/ratings
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  baseUrl: http://192.168.178.33:3000
}

docs {
  Returns the authenticated user's rating history with product details, most recent first.
}
