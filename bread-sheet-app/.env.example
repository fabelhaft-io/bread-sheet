EXPO_PUBLIC_SUPABASE_URL=https://<supabase_project>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=<supabase_project_key>
EXPO_PUBLIC_API_URL=http://<your-local-ip>:3000
# Must be reachable from the phone's browser — use your LAN IP, not localhost.
# Add this URL to Supabase → Authentication → URL Configuration → Redirect URLs.
EXPO_PUBLIC_AUTH_REDIRECT_URL=http://<your-local-ip>:3000/auth/callback