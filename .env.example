LOCALSTACK_AUTH_TOKEN=<local_stack_auth_token>

# Host path to your Google ADC credentials file, mounted into the server container
# for VISION_MODE=live (run 'gcloud auth application-default login' on the host first).
# Linux/macOS: ${HOME}/.config/gcloud/application_default_credentials.json
# Windows:     ${APPDATA}/gcloud/application_default_credentials.json
GCLOUD_ADC_PATH=${HOME}/.config/gcloud/application_default_credentials.json